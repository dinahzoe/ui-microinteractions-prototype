{
    "manifest_version": 3,
    "name": "Pausenbasierte Fokusunterstützung",
    "version": "1.0.0",
    "description": "Browser-Erweiterung zur Reduktion wahrgenommener Belastung durch strukturierte Pausen.",
    "permissions": [
        "notifications",
        "alarms",
        "tabs"
    ],
    "background": {
        "service_worker": "main.js"
    },
    "action": {
        "default_popup": "html/index.html"
    },
    "icons": {
        "16": "image/icon_start.png",
        "48": "image/icon_start.png",
        "128": "image/icon_start.png"
    }
}